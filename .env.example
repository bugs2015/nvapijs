# NVIDIA API Proxy 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# 基础配置
# ============================================

# NVIDIA API 基础 URL
NVIDIA_BASE=https://integrate.api.nvidia.com

# 密钥前缀
KEY_PREFIX=NV_KEY_

# 密钥数量
KEY_COUNT=3

# 最大并发数
MAX_CONCURRENCY=2

# 最大重试次数
MAX_RETRIES=1

# 默认最大 token 数
DEFAULT_MAX_TOKENS=4096

# 请求超时时间（毫秒）
REQUEST_TIMEOUT=30000

# ============================================
# NVIDIA API 密钥
# ============================================

# 请替换为您的实际 NVIDIA API 密钥
# 可以配置多个密钥以实现负载均衡
NV_KEY_1=your_nvidia_api_key_1
NV_KEY_2=your_nvidia_api_key_2
NV_KEY_3=your_nvidia_api_key_3

# ============================================
# 鉴权配置（可选）
# ============================================

# 最大鉴权令牌数（设置为 0 表示不启用鉴权）
MAXTOKEN=0

# 鉴权令牌（如果 MAXTOKEN > 0，则需要配置）
TOKEN_1=your_auth_token_1
TOKEN_2=your_auth_token_2
TOKEN_3=your_auth_token_3

# ============================================
# 高级配置（可选）
# ============================================

# Worker 名称（用于日志标识）
WORKER_NAME=nvidia-api-proxy

# 日志级别（DEBUG, INFO, WARN, ERROR）
LOG_LEVEL=INFO

# 启用性能监控
ENABLE_METRICS=true

# ============================================
# 注意事项
# ============================================

# 1. 永远不要将 .env 文件提交到 Git 仓库
# 2. 在生产环境中，建议使用 Cloudflare Secrets 管理敏感信息
# 3. 定期轮换 API 密钥和鉴权令牌
# 4. 根据实际需求调整并发数和超时时间
