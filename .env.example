# NVIDIA API 密钥配置
# 请将您的实际 NVIDIA API 密钥替换下面的值
NV_KEY_1=your_nvidia_api_key_1
NV_KEY_2=your_nvidia_api_key_2
NV_KEY_3=your_nvidia_api_key_3

# 访问鉴权 Token（可选）
# 如果设置了 MAXTOKEN > 0，则需要配置这些 Token
TOKEN_1=your_access_token_1
TOKEN_2=your_access_token_2

# 密钥配置前缀
KEY_PREFIX=NV_KEY_

# 密钥数量
KEY_COUNT=3

# 最大并发数
MAX_CONCURRENCY=2

# 最大 Token 数量（0 表示不限制鉴权）
MAXTOKEN=0

# 注意：这个文件仅用于本地开发参考
# 实际部署时，请使用 wrangler secret put 命令设置敏感信息
# 例如：wrangler secret put NV_KEY_1